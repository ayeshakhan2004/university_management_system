@page
@model UniversityProject.Pages.StudentPortalModel
@{ ViewData["Title"] = "Student Dashboard"; }

<div class="container mt-4">
    <div class="card shadow-sm mb-4 border-info">
        <div class="card-header bg-info text-white d-flex justify-content-between align-items-center">
            <h4 class="mb-0">🎓 Student Profile: @Model.StudentName</h4>
            <a href="/" class="btn btn-light btn-sm shadow-sm">Logout</a>
        </div>
        <div class="card-body bg-light">
            <div class="row">
                <div class="col-md-6">
                    <p><strong>Department:</strong> @Model.Department</p>
                    <p><strong>Phone:</strong> @Model.Phone</p>
                </div>
                <div class="col-md-6">
                    <p><strong>Address:</strong> @Model.Address</p>
                    <p><strong>Status:</strong> <span class="badge bg-success">Active</span></p>
                </div>
            </div>
        </div>
    </div>

    <h3 class="mb-3">📚 My Registered Courses</h3>
    <table class="table table-hover table-bordered shadow-sm">
        <thead class="table-dark">
            <tr>
                <th>Course Name</th>
                <th>Instructor</th>
                <th>Current Grade</th>
            </tr>
        </thead>
        <tbody>
            @if (Model.MyCourses.Count == 0) {
                <tr><td colspan="3" class="text-center text-muted">No courses found for this student.</td></tr>
            } else {
                @foreach (var course in Model.MyCourses) {
                    <tr>
                        <td>@course[0]</td>
                        <td>@course[1]</td>
                        <td><span class="badge bg-primary">@course[2]</span></td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>